DASHSCOPE_API_KEY=your-dashscope-api-key
QWEN_CHAT_MODEL=qwen3.5-plus
# 快速小模型（可选）：用于记忆检索路由等低延迟判断，需与 ALWAYS_SEARCH_LONG_TERM 配合使用
# QWEN_CHAT_MODEL_QUICK=qwen-turbo
# MEM0_USE_LLM_MEMORY_ROUTER=true
LOG_LEVEL=INFO
BOCHA_WEB_SEARCH_API_KEY=your-bocha-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Expense agent (LLM + persistent RAG)
# If omitted, the expense agent will fallback to QWEN_* and DASHSCOPE_* values above.
# EXPENSE_AGENT_MODEL=qwen-plus
# EXPENSE_AGENT_API_KEY=your-api-key
# EXPENSE_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EXPENSE_EMBEDDING_MODEL=text-embedding-v3
# EXPENSE_EMBEDDING_API_KEY=your-api-key
# EXPENSE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EXPENSE_RAG_PATH=./expense_rag_data
# EXPENSE_RAG_COLLECTION=expense_records
# EXPENSE_RAG_TOP_K=6
# EXPENSE_AGENT_EXPOSE_RAG_RECORDS=false

# 提示词目录（可选，为空则使用默认 bisheng_generator/prompts）
# PROMPTS_DIR=

# 毕昇平台地址（知识库、工作流导入均使用；Token 由前端配置，上线后从 Cookie 获取）
BISHENG_BASE_URL=http://localhost:3001

# MCP 工具搜索接口（已封装大模型筛选 + 向量检索，无需本地 LLM 调用）
MCP_SEARCH_URL=http://10.10.1.40:8000/api/mcp-search
MCP_SEARCH_TOP_K=5

# 容错重试（各节点最大重试次数，总调用次数 = 1 + 重试次数）
MAX_RETRIES_INTENT=2
MAX_RETRIES_TOOL=1
MAX_RETRIES_KNOWLEDGE=1
MAX_RETRIES_WORKFLOW=2

# 模型的参数
THINKING_BUDGET_INTENT=50
THINKING_BUDGET_WORKFLOW=100

# 数据库（工作流生成记录持久化，启动时自动建表）
# - 配置了 MySQL 连接信息时使用 MySQL
# - 未配置 MySQL 时自动 fallback 到 SQLite（零配置，数据存储在 bisheng_generator/data/bisheng_generator.db）
# - 设置 DB_ENABLED=false 可完全禁用数据库
DB_ENABLED=true

# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=bisheng_workflow
