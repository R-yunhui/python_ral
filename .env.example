DASHSCOPE_API_KEY=your-dashscope-api-key
QWEN_CHAT_MODEL=qwen3.5-plus
LOG_LEVEL=INFO
BOCHA_WEB_SEARCH_API_KEY=your-bocha-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 提示词目录（可选，为空则使用默认 bisheng_generator/prompts）
# PROMPTS_DIR=

# 毕昇平台地址（知识库、工作流导入均使用；Token 由前端配置，上线后从 Cookie 获取）
BISHENG_BASE_URL=http://localhost:3001

# MCP 工具搜索接口（已封装大模型筛选 + 向量检索，无需本地 LLM 调用）
MCP_SEARCH_URL=http://10.10.1.40:8000/api/mcp-search
MCP_SEARCH_TOP_K=5

# 容错重试（各节点最大重试次数，总调用次数 = 1 + 重试次数）
MAX_RETRIES_INTENT=2
MAX_RETRIES_TOOL=1
MAX_RETRIES_KNOWLEDGE=1
MAX_RETRIES_WORKFLOW=2

# 模型的参数
THINKING_BUDGET_INTENT=50
THINKING_BUDGET_WORKFLOW=100
